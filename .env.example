# Root environment example for UniGate
# Copy this file to the module you are working on and rename it to `.env`

# Backend
MONGODB_URI=mongodb://localhost:27017/unigate
GEMINI_API_KEY=your_gemini_api_key_here
PORT=5000

# Scraper / Extraction
GEMINI_MODEL=gemini-1.5-flash
RAW_DATA_DIR=../data/raw
PROCESSED_DATA_DIR=../data/processed
